from dataclasses import dataclass, field
from tsujikiri.ir import (
    IRBase as IRBase,
    IRClass as IRClass,
    IRCodeInjection as IRCodeInjection,
    IRConstructor as IRConstructor,
    IREnum as IREnum,
    IREnumValue as IREnumValue,
    IRExceptionRegistration as IRExceptionRegistration,
    IRField as IRField,
    IRFunction as IRFunction,
    IRMethod as IRMethod,
    IRModule as IRModule,
    IRParameter as IRParameter,
    IRProperty as IRProperty,
    IRUsingDeclaration as IRUsingDeclaration,
)

@dataclass
class TIRParameter(IRParameter):
    origin: IRParameter | None = field(default=None, init=False, repr=False, compare=False)
    emit: bool = ...
    rename: str | None = ...
    type_override: str | None = ...
    default_override: str | None = ...
    ownership: str = ...
    index: int = ...
    @property
    def binding_name(self) -> str: ...

@dataclass
class TIRBase(IRBase):
    origin: IRBase | None = field(default=None, init=False, repr=False, compare=False)
    emit: bool = ...

@dataclass
class TIRMethod(IRMethod):
    origin: IRMethod | None = field(default=None, init=False, repr=False, compare=False)
    emit: bool = ...
    rename: str | None = ...
    return_type_override: str | None = ...
    return_ownership: str = ...
    return_keep_alive: bool = ...
    allow_thread: bool = ...
    wrapper_code: str | None = ...
    doc: str | None = ...
    code_injections: list[IRCodeInjection] = field(default_factory=list)
    overload_priority: int | None = ...
    exception_policy: str | None = ...
    api_since: str | None = ...
    api_until: str | None = ...
    @property
    def binding_name(self) -> str: ...

@dataclass
class TIRConstructor(IRConstructor):
    origin: IRConstructor | None = field(default=None, init=False, repr=False, compare=False)
    emit: bool = ...
    doc: str | None = ...
    code_injections: list[IRCodeInjection] = field(default_factory=list)

